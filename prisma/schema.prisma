generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

// ENUMS
enum MovementType {
  INGRESO
  SALIDA
}

enum UserRole {
  ADMIN
  STAFF
}

// MODELS
model User {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  email     String     @unique
  password  String
  role      UserRole
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  movements Movement[]

  @@map("users")
}

model Category {
  id          Int       @id @default(autoincrement())
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive])
  @@map("categories")
}

model Product {
  id           Int            @id @default(autoincrement())
  sku          String         @unique
  alias        String
  description  String?
  brand        String?
  categoryId   Int
  currentStock Int            @default(0)
  minStock     Int            @default(5)
  unitsPerBox  Int?
  imageUrl     String?
  isActive     Boolean        @default(true)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  movements    Movement[]
  category     Category       @relation(fields: [categoryId], references: [id])
  colors       ProductColor[]

  @@index([isActive])
  @@index([categoryId])
  @@map("products")
}

model Movement {
  id           Int             @id @default(autoincrement())
  productId    Int
  userId       Int
  type         MovementType
  quantity     Int             @default(1)
  observations String?
  receivedBy   String?
  createdAt    DateTime        @default(now())
  product      Product         @relation(fields: [productId], references: [id])
  user         User            @relation(fields: [userId], references: [id])
  colors       MovementColor[]

  @@index([productId])
  @@index([userId])
  @@index([type])
  @@index([createdAt])
  @@map("movements")
}

model ProductColor {
  id           Int             @id @default(autoincrement())
  productId    Int
  name         String
  hexCode      String?
  currentStock Int             @default(0)
  product      Product         @relation(fields: [productId], references: [id])
  movements    MovementColor[]

  @@unique([productId, name])
  @@map("product_colors")
}

model MovementColor {
  id             Int          @id @default(autoincrement())
  movementId     Int
  productColorId Int
  quantity       Int
  movement       Movement     @relation(fields: [movementId], references: [id])
  productColor   ProductColor @relation(fields: [productColorId], references: [id])

  @@map("movement_colors")
}

model RolePermission {
  id         Int      @id @default(autoincrement())
  role       UserRole
  permission String

  @@unique([role, permission])
  @@map("role_permissions")
}
